# ---- MongoDB connection ----
# Paste your MongoDB connection string here (Atlas or self-hosted).
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority

# Database + collection where futures data is stored
MONGO_DB=nse_fno
MONGO_COLLECTION=stock_futures
# Collection used to track which dates are already ingested (for resume)
MONGO_PROGRESS_COLLECTION=ingest_progress

# ---- Backfill window ----
# Number of years of history to pull (from today going back).
YEARS_BACK=7
# Optional explicit range (YYYY-MM-DD). If set, these override YEARS_BACK.
# START_DATE=2019-07-08
# END_DATE=2026-07-08

# ---- Politeness / rate limiting (to avoid being blocked by NSE) ----
# Seconds to sleep between each day's download.
REQUEST_DELAY=1.5
# Max retries per download on transient errors, with exponential backoff.
MAX_RETRIES=4

# ---- What to ingest ----
# Instrument types to keep. Stock futures only by default.
# Old-format codes: FUTSTK (stock), FUTIDX (index)
# New UDiFF codes:  STF (stock),    IDF (index)
# Use logical names here: STOCK_FUT and/or INDEX_FUT (comma separated)
INSTRUMENTS=STOCK_FUT
